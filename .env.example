# AI CFO System — Environment Variables
# Copy to .env and fill in real values

# ── Anthropic (Required) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector for production
DATABASE_URL=postgresql://cfo_user:password@localhost:5432/ai_cfo_db

# SQLite for local development (no PostgreSQL required)
# DATABASE_URL=sqlite:///./ai_cfo.db

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
API_KEY=your-api-key-for-auth

# ── pgvector (production RAG — leave empty to use SQLite locally) ───────────
PGVECTOR_URL=postgresql://cfo_user:cfo_pass@localhost:5432/ai_cfo_db
# PGVECTOR_URL=  # empty → SQLite vector store (local dev / CI)

# ── LLM Backend ───────────────────────────────────────────────────────────────
LLM_BACKEND=anthropic   # anthropic | ollama
# OLLAMA_BASE_URL=http://localhost:11434   # only needed for ollama backend

# ── Vector Store (local dev / CI only — ignored when PGVECTOR_URL is set) ───
VECTORSTORE_PATH=./data/vectorstore.db

# ── Redis (optional — for Celery background tasks) ──────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
DEBUG=false
