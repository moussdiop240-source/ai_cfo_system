# AI CFO System — environment variables
# Copy to .env and fill in real values before running.
# Never commit .env to version control.

# ── LLM backend ──────────────────────────────────────────────────────────────
# "ollama"     → 100% local, no API key needed, data never leaves the machine
# "anthropic"  → cloud, requires ANTHROPIC_API_KEY
# "auto"       → Anthropic if key is set, else Ollama
LLM_BACKEND=ollama
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, local dev):
DATABASE_URL=sqlite:///./ai_cfo.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:pass@host:5432/ai_cfo

# ── pgvector (optional RAG upgrade) ──────────────────────────────────────────
# Leave blank to use the built-in SQLite vector store
PGVECTOR_URL=

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Redis URL for multi-instance / multi-pod deployments.
# Omit (or leave blank) for in-memory limiting (single instance only — resets on restart).
REDIS_URL=
# Production example: REDIS_URL=redis://localhost:6379/0

# ── Security / RBAC ──────────────────────────────────────────────────────────
# JSON map of API key → role (or role + expiry).
# Simple:  {"my-key": "cfo"}
# Expiry:  {"my-key": {"role": "cfo", "expires": "2026-12-31"}}
RBAC_KEYS=

# Single admin key (fallback if RBAC_KEYS not set). Must be >= 32 chars in production.
ADMIN_API_KEY=change-me-to-at-least-32-random-characters

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Leave blank to allow all origins (*) — restrict in production.
CORS_ORIGINS=
# Production example: CORS_ORIGINS=https://yourapp.com,https://admin.yourapp.com

# ── Streamlit UI auth ─────────────────────────────────────────────────────────
# Option A: shared password (simple, single user)
STREAMLIT_PASSWORD=
# Option B: per-user bcrypt hashes (JSON map, takes precedence over STREAMLIT_PASSWORD)
# Generate hash: python -c "import bcrypt; print(bcrypt.hashpw(b'mypassword', bcrypt.gensalt()).decode())"
# STREAMLIT_USERS={"alice": "$2b$12$...", "bob": "$2b$12$..."}
STREAMLIT_USERS=

# ── Field-level encryption ────────────────────────────────────────────────────
# Fernet key to encrypt sensitive database columns at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to store plaintext (dev mode). Existing plaintext rows still readable after enabling.
FIELD_ENCRYPTION_KEY=

# ── Distributed tracing (OpenTelemetry) ──────────────────────────────────────
# Set to an OTLP endpoint to export traces (Jaeger, Grafana Tempo, Honeycomb, etc.)
# Leave blank to disable tracing entirely (zero overhead, no dependency).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-cfo-system

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development

# ── Vector store ──────────────────────────────────────────────────────────────
VECTORSTORE_PATH=./data/vectorstore.db

# ── Legacy (kept for backward compat) ─────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
