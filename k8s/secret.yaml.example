# Copy to secret.yaml, fill in real values, then apply with:
#   kubectl apply -f k8s/secret.yaml
# NEVER commit secret.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: ai-cfo-secrets
  namespace: ai-cfo
type: Opaque
stringData:
  DATABASE_URL: "postgresql://ai_cfo:changeme@postgres-service:5432/ai_cfo"
  ANTHROPIC_API_KEY: ""
  ADMIN_API_KEY: "replace-with-at-least-32-random-characters-here"
  # JSON map: {"alice": {"role": "cfo", "expires": "2027-12-31"}}
  RBAC_KEYS: ""
  REDIS_URL: "redis://redis-service:6379/0"
  CORS_ORIGINS: "https://yourapp.example.com"
  STREAMLIT_PASSWORD: ""
  # Per-user bcrypt auth: {"alice": "$2b$12$...", "bob": "$2b$12$..."}
  STREAMLIT_USERS: ""
  # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
  FIELD_ENCRYPTION_KEY: ""
